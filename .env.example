# ============================================================================
# SYNTHEA ETL - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy file này thành .env và chỉnh sửa theo môi trường của bạn
# Windows: copy .env.example .env
# Linux/Mac: cp .env.example .env
# ============================================================================

# SQL Server Configuration
# -------------------------
# Tên SQL Server instance (server hoặc server\instance)
# Examples:
#   LAPTOP-GE6ISH50            (máy local theo mặc định của project)
#   localhost                  (default instance trên máy local)
#   DESKTOP-ABC123\SQLEXPRESS  (named instance)
#   192.168.1.100              (remote server)
#   myserver.domain.com        (domain server)
SYNTHEA_SQL_SERVER=<tên SQL Server của bạn>

# (Optional) Force a specific ODBC driver. If blank, script chọn driver tốt nhất tự động.
# Examples: ODBC Driver 18 for SQL Server, ODBC Driver 17 for SQL Server
#SYNTHEA_ODBC_DRIVER=

# Performance / batching (tùy biến theo môi trường)
SYNTHEA_CHUNK_SIZE=50000
SYNTHEA_BATCH_SIZE=20000

# Insert method: "executemany" hoặc "bulk_insert" (bulk_insert cần cấu hình BULK_DIR và quyền cho SQL Server)
SYNTHEA_INSERT_METHOD=executemany

# Optional: chỉ định thư mục tạm cho bulk files nếu dùng bulk insert
# Path phải có thể truy cập được bởi service SQL Server (ví dụ: a shared path)
#SYNTHEA_BULK_DIR=data/bulk

# ============================================================================
# NOTES
# ============================================================================
# - Script hiện tại sử dụng Windows Authentication (Trusted Connection)
# - Không cần username/password trong .env
# - Windows user của bạn phải có quyền truy cập vào SQL Server và databases
# - Nếu không kết nối được, kiểm tra:
#   1. SQL Server đang chạy
#   2. Windows Authentication enabled
#   3. User của bạn có trong SQL Server Logins
# ============================================================================
