# ============================================================================
# SYNTHEA ETL - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy file này thành .env và chỉnh sửa theo môi trường của bạn
# Windows: copy .env.example .env
# Linux/Mac: cp .env.example .env
# ============================================================================

# SQL Server Configuration
# -------------------------
# Tên SQL Server instance
# Examples:
#   localhost                    (default instance trên máy local)
#   DESKTOP-ABC123\SQLEXPRESS    (named instance)
#   192.168.1.100                (remote server)
#   myserver.domain.com          (domain server)
SYNTHEA_SQL_SERVER=localhost

# Nếu để trống, script sẽ tự động chọn ODBC Driver tốt nhất
# Hoặc chỉ định cụ thể:
#   ODBC Driver 18 for SQL Server
#   ODBC Driver 17 for SQL Server
# SYNTHEA_ODBC_DRIVER=

# ============================================================================
# NOTES
# ============================================================================
# - Script này CHỈ dùng Windows Authentication
# - Không cần cấu hình username/password
# - Windows user của bạn phải có quyền truy cập SQL Server
# - Nếu không kết nối được, kiểm tra:
#   1. SQL Server đang chạy
#   2. Windows Authentication enabled
#   3. User của bạn có trong SQL Server Logins
# ============================================================================
