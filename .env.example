# Environment Variables for Synthea ETL
# Copy this file to .env and update the values for your SQL Server setup

# SQL Server Configuration
# Set your SQL Server instance name (e.g., localhost, .\SQLEXPRESS, server-name\instance)
SYNTHEA_SQL_SERVER=localhost

# ODBC Driver (usually "ODBC Driver 17 for SQL Server" or "ODBC Driver 18 for SQL Server")
SYNTHEA_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# Optional: SQL Server credentials (leave empty for Windows Authentication)
# SYNTHEA_SQL_USER=
# SYNTHEA_SQL_PASSWORD=