                <component
                  refId="Package\Load Fact\Load Fact_Encounters\OLE DB Source"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="OLE DB Source"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    e.Id AS encounter_id,
    dbo.fn_date_key(CONVERT(DATE, e.[START])) AS encounter_date_key,
    ISNULL(p.patient_key, -1) AS patient_key,
    ISNULL(pr.provider_key, -1) AS provider_key,
    ISNULL(o.organization_key, -1) AS organization_key,
    ISNULL(pa.payer_key, -1) AS payer_key,
    e.CODE AS encounter_code,
    e.ENCOUNTERCLASS AS encounter_class,
    e.DESCRIPTION AS encounter_description,
    e.REASONCODE AS reason_code,
    ISNULL(e.BASE_ENCOUNTER_COST, 0) AS base_cost,
    ISNULL(e.TOTAL_CLAIM_COST, 0) AS total_claim_cost,
    ISNULL(e.PAYER_COVERAGE, 0) AS payer_coverage
FROM [DW_Synthea_Staging].[dbo].[Staging_Encounters] e
OUTER APPLY (SELECT TOP 1 patient_key FROM dbo.dim_patient d WHERE d.patient_id = e.PATIENT AND CONVERT(DATE, e.[START]) BETWEEN d.valid_from AND d.valid_to ORDER BY d.valid_from DESC) p
OUTER APPLY (SELECT TOP 1 provider_key FROM dbo.dim_provider d WHERE d.provider_id = e.PROVIDER AND CONVERT(DATE, e.[START]) BETWEEN d.valid_from AND d.valid_to ORDER BY d.valid_from DESC) pr
OUTER APPLY (SELECT TOP 1 organization_key FROM dbo.dim_organization d WHERE d.organization_id = e.ORGANIZATION AND CONVERT(DATE, e.[START]) BETWEEN d.valid_from AND d.valid_to) o
OUTER APPLY (SELECT TOP 1 payer_key FROM dbo.dim_payer d WHERE d.payer_id = e.PAYER AND CONVERT(DATE, e.[START]) BETWEEN d.valid_from AND d.valid_to) pa
WHERE e.Id IS NOT NULL; -- ĐÃ BỎ LỌC NGÀY</property>
